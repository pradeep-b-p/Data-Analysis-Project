zkxSnGIzPDPzGqkeRU_lI3JylNCrHxM1-yU6DE9r1Zg&oe=69F897F5","width":480},{"height":320,"url":"https:\/\/instagram.fblr22-1.fna.fbcdn.net\/v\/t51.82787-15\/670491035_18580467934033671_5793564918699343861_n.jpg?stp=c0.135.1080.1080a_dst-jpg_e35_s320x320_tt6&_nc_cat=109&ig_cache_key=Mzg3Mzg2OTA5MDMxNDAxODA1NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4MTM1MC5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=q4psq_4KwzQQ7kNvwGjaX_z&_nc_oc=AdqWHxo0gVJmsrIvONw7aYfPS5XP3afPslBILbQOK9RvcO_VAwFJ-ltzEC3eX6uO5iwKNKDcepssQO9t6ZoSqeH5&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-1.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af1ueyHAC5_f_FBQKYcdzBGCtR2tG5hx4DBC5WmfVrNnXQ&oe=69F897F5","width":320},{"height":240,"url":"https:\/\/instagram.fblr22-1.fna.fbcdn.net\/v\/t51.82787-15\/670491035_18580467934033671_5793564918699343861_n.jpg?stp=c0.135.1080.1080a_dst-jpg_e35_s240x240_tt6&_nc_cat=109&ig_cache_key=Mzg3Mzg2OTA5MDMxNDAxODA1NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4MTM1MC5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=q4psq_4KwzQQ7kNvwGjaX_z&_nc_oc=AdqWHxo0gVJmsrIvONw7aYfPS5XP3afPslBILbQOK9RvcO_VAwFJ-ltzEC3eX6uO5iwKNKDcepssQO9t6ZoSqeH5&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-1.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af00L4YiP6UGvYvFw7U5ox3ECtphJw6yp_IvMZu2yIGezw&oe=69F897F5","width":240},{"height":150,"url":"https:\/\/instagram.fblr22-1.fna.fbcdn.net\/v\/t51.82787-15\/670491035_18580467934033671_5793564918699343861_n.jpg?stp=c0.135.1080.1080a_dst-jpg_e35_s150x150_tt6&_nc_cat=109&ig_cache_key=Mzg3Mzg2OTA5MDMxNDAxODA1NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4MTM1MC5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=q4psq_4KwzQQ7kNvwGjaX_z&_nc_oc=AdqWHxo0gVJmsrIvONw7aYfPS5XP3afPslBILbQOK9RvcO_VAwFJ-ltzEC3eX6uO5iwKNKDcepssQO9t6ZoSqeH5&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-1.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af3bpwb0P6O9T1avi_HXa9PUTE6jFsSxkamkmT4-lYu0hg&oe=69F897F5","width":150}]},"code":"DXCxEsmFNMz","media_cropping_info":null,"profile_grid_thumbnail_fitting_style":"UNSET","media_overlay_info":null,"preview":null,"product_type":"carousel_container","thumbnails":null,"timeline_pinned_user_ids":["26849670"],"upcoming_event":null,"user":{"pk":"26849670","username":"akwasibrenyamensa","id":"26849670"},"media_notes":null,"like_count":987,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":122,"comments_disabled":null,"view_count":null,"id":"3873874456532538163_26849670"},{"pk":"3871507294533456692","accessibility_caption":null,"caption":{"pk":"18086673872594495","text":"Atelier Jolie is proud to partner with \u0040eatoffbeat to celebrate the culinary talents of refugee and immigrant chefs through unique dinner and demonstration evenings in the Eat Offbeat Caf\u00e9. We were pleased to welcome Chef Ala\u2019a \u0040alaa__amer to share personal recipes of Yemeni cuisine with our guests and neighbors.\u00a0\n\nChef Ala\u2019a Amer is a Yemeni-American producer, filmmaker, and food enthusiast working between the United States and the MENA region. Her work\u2014both on screen and at the table\u2014centers on sharing stories from Yemen. She arrived in the United States nearly a decade ago as a PhD student, and when war broke out in Yemen, what was meant to be temporary became permanent. Navigating a new life and rebuilding from the ground up, she found her way into film, telling stories that might otherwise go unseen. As a woman of color and an immigrant, Ala\u2019a learned early that belonging is not given\u2014it is built, and for her, that process began around a table. Cooking has been a constant in her life; growing up in Yemen, she spent her afternoons beside her mother in the kitchen, absorbing flavors and traditions. It was only after leaving that she understood the depth of what she carried with her, and food became her first language for sharing where she comes from\u2014an intimate way to connect across cultures. Whether through film or food, Ala\u2019a\u2019s work is rooted in creating connection and preserving culture, introducing Yemeni cuisine and stories not as something distant, but as something deeply human\u2014worth knowing, worth celebrating, and worth preserving.\n\nAt every class, guests receive expert guidance and cultural insights as they learn to prepare dishes step by step. Afterwards, guests enjoy a beautiful evening of connection as they dine and share stories with fellow food lovers. To reserve your seat for upcoming sessions, please visit the link in our bio. \n\nPhotos by \u0040adam_shaarani \n\n#AtelierJolie #EatOffbeat"},"audience":null,"carousel_media_count":4,"display_uri":"https:\/\/instagram.fblr22-2.fna.fbcdn.net\/v\/t51.82787-15\/669870183_18002749580911906_3372239066267316957_n.jpg?stp=c240.0.960.960a_dst-jpg_e15_tt6&_nc_ht=instagram.fblr22-2.fna.fbcdn.net&_nc_cat=110&_nc_oc=Q6cZ2gHmZd-p7XYzy5pLKsZtihhCVS_Oq1AWYpTl5-7UJpHhRXXq994tOWs_CrRZ-HehRP-5AyDt0xEYj4c-naemPU4h&_nc_ohc=6zdlbpP87IoQ7kNvwEtsbsh&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&edm=APs17CUBAAAA&ccb=7-5&oh=00_Af0BYcFN9blS12caxWKSTFD3qKpnoLndFgLa5B8AlJZ4CA&oe=69F8969C&_nc_sid=10d13b","media_type":8,"carousel_media":[{"image_versions2":{"candidates":[{"height":960,"url":"https:\/\/instagram.fblr22-2.fna.fbcdn.net\/v\/t51.82787-15\/669870183_18002749580911906_3372239066267316957_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=107&ig_cache_key=Mzg3MTIxNzgwODAxNjcwMjQ2MQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0NDB4OTYwLnNkci5DMyJ9&_nc_ohc=mlp89TL7wEkQ7kNvwEHL6J8&_nc_oc=AdpcO2Wu56gZX4T6X0c04GUaZASc0j1q0Cp6i0uajkZQXn3QN7bqFIJkaAsgvBBeL0AV8m44Y2YnDMpRfd-Jhs0e&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-2.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af3zZ8Q8b8CGaS-rEpa8FsUvx5cDl7xXxUt_-o3gemFo2A&oe=69F8969C","widt