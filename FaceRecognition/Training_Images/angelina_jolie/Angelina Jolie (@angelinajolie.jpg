Eu_j-V5xklZTaSkKHJEQHbDvY34rJpe5V2oA6xA3wrZsbpw3NR&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-2.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af3TSCy1T0HWenMG3nO7Ts9k0elEUiWyV-uGVALfWI4Scg&oe=69F88BCA","width":320},{"height":240,"url":"https:\/\/instagram.fblr22-2.fna.fbcdn.net\/v\/t51.82787-15\/683925315_18005304176911906_310924076185750018_n.jpg?stp=c395.0.2236.2236a_dst-jpg_e35_s240x240_tt6&_nc_cat=100&ig_cache_key=Mzg4NjE2ODgwMjQ5NzQ2NDA1OA\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjMwMjZ4MjIzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=JyAKfa8GJYcQ7kNvwHOYNzO&_nc_oc=AdpyjoHYR5XmmAxLPoRoDCkQwLIpdjUkLt2c0KEu_j-V5xklZTaSkKHJEQHbDvY34rJpe5V2oA6xA3wrZsbpw3NR&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-2.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af0ZJRaXCgLuQeR_OT3XNPO5ZVqRWeWLTW8JkMOUIb-P4Q&oe=69F88BCA","width":240},{"height":150,"url":"https:\/\/instagram.fblr22-2.fna.fbcdn.net\/v\/t51.82787-15\/683925315_18005304176911906_310924076185750018_n.jpg?stp=c395.0.2236.2236a_dst-jpg_e35_s150x150_tt6&_nc_cat=100&ig_cache_key=Mzg4NjE2ODgwMjQ5NzQ2NDA1OA\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjMwMjZ4MjIzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=JyAKfa8GJYcQ7kNvwHOYNzO&_nc_oc=AdpyjoHYR5XmmAxLPoRoDCkQwLIpdjUkLt2c0KEu_j-V5xklZTaSkKHJEQHbDvY34rJpe5V2oA6xA3wrZsbpw3NR&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-2.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af0fpUgjAs6WLEnrkT3a7A6ryvH6OnR8s6B2KPtoFR9JAg&oe=69F88BCA","width":150}]},"code":"DXucl3oEUMm","media_cropping_info":null,"profile_grid_thumbnail_fitting_style":"UNSET","media_overlay_info":null,"preview":null,"product_type":"carousel_container","thumbnails":null,"timeline_pinned_user_ids":[],"upcoming_event":null,"user":{"pk":"57256207905","username":"atelierjolieofficial","id":"57256207905"},"media_notes":null,"like_count":305,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":10,"comments_disabled":null,"view_count":null,"id":"3886169276118287142_57256207905"},{"pk":"3879630701464657796","accessibility_caption":null,"caption":{"pk":"18262858069291998","text":"Atelier Jolie welcomed Chef Lebjulet with \u0040eatoffbeat for a sold out dinner and demonstration in the Eat Offbeat Caf\u00e9 that brought our guests and neighbors into the heart of Venezuelan culture.\u00a0\n\nChef Lebjulet is a Venezuelan-born culinary artist, educator, and storyteller who has called New York home for the past eight years. Before moving to the U.S., she was a professor in Mechanical Engineering, bringing precision, creativity, and discipline into her culinary work. She leads her own venture, Juliette\u2019s Bakery, an online bakery where she continues to bring Venezuelan traditions to life through desserts and baked goods rooted in memory, heritage, and care. Raised in a culture where food is deeply tied to family and community, Lebjulet learned to cook alongside her loved ones, participating in traditions like communal tomato sauce-making a celebration of togetherness and heritage. Through her work, she shares the warmth and hospitality of Venezuela, using food as a way to connect people, celebrate culture, and create a sense of belonging. Chef Lebjulet has been collaborating with \u0040eatoffbeat since 2019, sharing her culture and flavors through thoughtfully crafted dishes and experiences. \n\nTo attend a dinner and demonstration, please visit the link in our bio for a full schedule of offerings.\u00a0\n\n#AtelierJolie #EatOffbeat"},"audience":null,"carousel_media_count":null,"display_uri":"https:\/\/instagram.fblr22-2.fna.fbcdn.net\/v\/t51.82787-15\/671126109_18004123448911906_4422935348679324821_n.jpg?stp=c0.240.1440.1440a_dst-jpg_e35_s1080x1080_sh2.08_tt6&_nc_ht=instagram.fblr22-2.fna.fbcdn.net&_nc_cat=110&_nc_oc=Q6cZ2gHmZd-p7XYzy5pLKsZtihhCVS_Oq1AWYpTl5-7UJpHhRXXq994tOWs_CrRZ-H