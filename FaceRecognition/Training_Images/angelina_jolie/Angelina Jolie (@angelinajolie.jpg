ified":false,"username":"lalaboy_beyouurios","id":"73328028194"},"has_liked_comment":null}],"view_count":null,"top_likers":null,"hidden_likes_string_variant":-1,"fb_like_count":null,"crosspost_metadata":null,"social_context":null,"can_reshare":null,"enable_media_notes_production":false,"media_repost_count":null,"saved_collection_ids":null,"has_viewer_saved":null,"sharing_friction_info":{"should_have_sharing_friction":false,"bloks_app_url":null},"caption":{"text":"Atelier Jolie proudly presents the Tatale \u0040tataleworld Dining Series by \u0040akwasibrenyamensa.\u2028\u2028Born in Ghana and developed in London, Tatale is a contemporary Pan-African concept that tells stories through food, art and heritage.\u2028\u2028Presented weekly, \u0040akwasibrenyamensa brings a series of intimate dinners to Atelier Jolie, becoming the first-ever culinary artist to offer a dining experience within the creative hub. The series explores a program of evolving menus, inviting artists and makers including \u0040hawahassan \u0040natashapickowicz and \u0040artcomesfirst to collaborate through communal dining.\n\nOpens Friday, April 24, 2026. Details at the link in our bio.\n\nPhotos by \u0040argenisphoto\n\n#AtelierJolie #Tatale #AkwasiBrenyaMensa","pk":"18119839516635391","has_translation":null,"created_at":1776358895},"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"can_see_insights_as_brand":false,"affiliate_info":null,"ig_media_sharing_disabled":false,"share_ids":null,"feed_demotion_control":null,"feed_recs_demotion_control":null,"main_feed_carousel_starting_media_id":null,"owner":{"show_account_transparency_details":true,"id":"57256207905"},"is_shared_from_basel":null,"fb_comment_count":null,"all_previous_submitters":null,"follow_hashtag_info":null,"media_attributions_data":[],"wearable_attribution_info":null,"caption_is_edited":true,"commenting_disabled_for_viewer":null}]}},"extensions":{"is_final":true,"all_video_dash_prefetch_representations":[]}},"sequence_number":0}}]],["CometResourceScheduler","registerHighPriHashes",null,[["MaHhERz","8lMIq7p"]]]]}},{"__bbox":null},{"__bbox":null}]]]}</script>
