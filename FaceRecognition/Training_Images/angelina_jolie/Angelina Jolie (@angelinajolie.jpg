osted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":39,"comments_disabled":null,"view_count":null,"id":"3879630701464657796_57256207905"},{"pk":"3878925432721288181","accessibility_caption":null,"caption":{"pk":"18071484932291374","text":"For the opening night of the Tatale Dining Series (\u0040tataleworld) at \u0040atelierjolieofficial, I\u2019m honoured to welcome \u0040hawahassan.\n\nHawa Hassan is a James Beard Award winner, the author of In Bibi\u2019s Kitchen and Setting a Place for Us, host of Food Network\u2019s Hawa at Home and Cooking Channel\u2019s Spice of Life, and Founder & CEO of \u0040basbaasfoods.\n\nJoin us on Friday, April 24 for the first dinner in the series \ud83d\ude80\n\n18:00\u201320:15 \nTickets and further information at the link in bio.\n\n#Tatale #AtelierJolie #HawaHassan #AkwasiBrenyaMensa"},"audience":null,"carousel_media_count":2,"display_uri":"https:\/\/instagram.fblr22-1.fna.fbcdn.net\/v\/t51.82787-15\/670814604_18582079126033671_7208224129193953966_n.jpg?stp=c0.135.1080.1080a_dst-jpg_e15_fr_s1080x1080_tt6&_nc_ht=instagram.fblr22-1.fna.fbcdn.net&_nc_cat=103&_nc_oc=Q6cZ2gHmZd-p7XYzy5pLKsZtihhCVS_Oq1AWYpTl5-7UJpHhRXXq994tOWs_CrRZ-HehRP-5AyDt0xEYj4c-naemPU4h&_nc_ohc=O18AVn3SM9QQ7kNvwFhBpXg&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&edm=APs17CUBAAAA&ccb=7-5&oh=00_Af2d6D4LRx997mI4nj-SuHhlCFSyB0Fp1DC5E2aJcR4obQ&oe=69F8A238&_nc_sid=10d13b","media_type":8,"carousel_media":[{"image_versions2":{"candidates":[{"height":1350,"url":"https:\/\/instagram.fblr22-1.fna.fbcdn.net\/v\/t51.82787-15\/670814604_18582079126033671_7208224129193953966_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=106&ig_cache_key=Mzg3ODkyMzI3MDE3MDg5MDc1OQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4MTM1MC5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=B2Lh5O5Cg4QQ7kNvwGfFLlm&_nc_oc=AdpI0Ix73vnofnCoxoCHFC8EYFknUd5NfhIrd_S9v-QhWWGlWUBNnIPoiwcyEFh6ecOa2b571H3lUIM7cEQZuUbV&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagr