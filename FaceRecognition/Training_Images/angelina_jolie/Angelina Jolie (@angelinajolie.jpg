c_zt=23&_nc_ht=instagram.fblr22-2.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af1BThHchy_JTZCnR8E7QhvVdQ_lQ9gUsK-VwmeTmxhKRg&oe=69F8969C","width":240},{"height":150,"url":"https:\/\/instagram.fblr22-2.fna.fbcdn.net\/v\/t51.82787-15\/669870183_18002749580911906_3372239066267316957_n.jpg?stp=c240.0.960.960a_dst-jpg_e35_s150x150_tt6&_nc_cat=107&ig_cache_key=Mzg3MTIxNzgwODAxNjcwMjQ2MQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0NDB4OTYwLnNkci5DMyJ9&_nc_ohc=mlp89TL7wEkQ7kNvwEHL6J8&_nc_oc=AdpcO2Wu56gZX4T6X0c04GUaZASc0j1q0Cp6i0uajkZQXn3QN7bqFIJkaAsgvBBeL0AV8m44Y2YnDMpRfd-Jhs0e&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-2.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af0E4qfij8WpnJEaxtBXXpqRW77qv81vsxY4d79ptiKozw&oe=69F8969C","width":150}]},"code":"DW6W19MABM0","media_cropping_info":null,"profile_grid_thumbnail_fitting_style":"UNSET","media_overlay_info":null,"preview":null,"product_type":"carousel_container","thumbnails":null,"timeline_pinned_user_ids":[],"upcoming_event":null,"user":{"pk":"57256207905","username":"atelierjolieofficial","id":"57256207905"},"media_notes":null,"like_count":930,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":45,"comments_disabled":null,"view_count":null,"id":"3871507294533456692_57256207905"},{"pk":"3870903307853682723","accessibility_caption":null,"caption":{"pk":"18100066100316704","text":"Atelier Jolie welcomes a new Artist in Residence this spring, Ghanaian-British artist \u0040AkwasiBrenyaMensa. \n\nCentred on gathering as method, Brenya-Mensa creates sensory environments through space, sound, memory, image and food. Most recently known for his Pan-African dining concept \u0040tataleworld, his practice explores public convening as a structured mode of inquiry and exchange through the ritual of dining together. The first floor becomes a working site for experimentation and collaboration in dialogue with Atelier Jolie\u2019s mission.\n\nPublic programming will begin April 2026. Link in bio.\n\nPhotos by \u0040argenisphoto\n\n#AtelierJolie #AkwasiBrenyaMensa #Tatale"},"audience":null,"carousel_media_count":4,"display_uri":"https:\/\/instagram.fblr22-2.fna.fbcdn.net\/v\/t51.82787-15\/661699114_18002683997911906_4269330847046413241_n.jpg?stp=c0.135.1080.1080a_dst-jpg_e15_fr_s1080x1080_tt6&_nc_ht=instagram.fblr22-2.fna.fbcdn.net&_nc_cat=110&_nc_oc=Q6cZ2gHmZd-p7XYzy5pLKsZtihhCVS_Oq1AWYpTl5-7UJpHhRXXq994tOWs_CrRZ-HehRP-5AyDt0xEYj4c-naemPU4h&_nc_ohc=sHvU8c7gk0IQ7kNvwEEp1UI&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&edm=APs17CUBAAAA&ccb=7-5&oh=00_Af0Jwxx9XksiFUXcRX0E_lEhwxfcePflUkieMWsh9j4vRw&oe=69F89FF0&_nc_sid=10d13b","media_type":8,"carousel_media":[{"image_versions2":{"candidates":[{"height":1350,"url":"https:\/\/instagram.fblr22-1.fna.fbcdn.net\/v\/t51.82787-15\/661699114_18002683997911906_4269330847046413241_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=103&ig_cache_key=Mzg3MDgzNzMwNDI0NzQ2NTc5OQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4MTM1MC5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=EfjSqIJBeRUQ7kNvwF4oFHo&_nc_oc=Ado5k6M2Ev5aRmWiW1AStU_1fpoyqHDSihbsWhkWsyW_gUk8W2CClDpXBFHvAjdPg8yCXIsj_dEfUXRgFursOG4q&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-1.fna&_nc_gid=KhcTJbaPmf4R6u-jWLsrkQ&_nc_ss=7a22e&oh=00_Af2bZU9rCJEnxzht5kaAXQKj1-IrlyX0C4qBaA360pipww&oe=69F89FF0","width":1080},{"height":900,"url":"https:\/\/instagram.fblr22-1.fna.fbcdn.net\/v\/t51.82787-15\/661699114_18002683997911906_4269330847046413241_n.jpg?stp=dst-jpg_e35_p720x720_tt6&_nc_cat=103&ig_cache_key=Mzg3MDgzNzMwNDI0NzQ2NTc5OQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4MTM1MC5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=EfjSqIJBeRUQ7kNvwF4oFHo&_nc_oc=Ado5k6M2Ev5aRmWiW1AStU_1fpoyqHDSihbsWhkWsyW_gUk8W2CClDpXBFHvAjdPg8yCXIsj_dEfUXRgFursOG4q&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fblr22-1.fna&_nc_gid=KhcTJbaPmf4R